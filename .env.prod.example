# Copy to .env.prod and fill in real values before deploying.
# .env.prod must never be committed to version control.

# ======================
# Django
# ======================
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
# Include the internal host the frontend proxy uses (it forwards Host=target),
# e.g. the in-cluster Service name, alongside the public domain.
DJANGO_ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,portfolio
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
WAGTAIL_BASE_URL=https://yourdomain.com

# ======================
# Database
# ======================
POSTGRES_DB=portfolio
POSTGRES_USER=portfolio
POSTGRES_PASSWORD=change-me-to-a-strong-password

# ======================
# App bind — backend defaults to 3000 (frontend is the public :8000)
# ======================
APP_HOST=0.0.0.0
APP_PORT=3000

# ======================
# Image
# ======================
# Pin to a specific git SHA for reproducible deploys, or leave as "latest"
IMAGE_TAG=latest
