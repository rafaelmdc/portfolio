# ======================
# Django
# ======================
DJANGO_DEBUG=0
DJANGO_SECRET_KEY=dev-secret-change-me
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://example.com,https://www.example.com
WAGTAIL_BASE_URL=https://example.com

# ======================
# Database
# ======================
POSTGRES_DB=portfolio
POSTGRES_USER=portfolio
POSTGRES_PASSWORD=change_me

# ======================
# App bind (INSIDE) — backend defaults to 3000 (frontend is the public :8000)
# ======================
APP_HOST=0.0.0.0
APP_PORT=3000

# ======================
# Host mapping (OUTSIDE)
# ======================
HOST_PORT=3000

# container names
DB_CONTAINER_NAME=portfolio-db
WEB_CONTAINER_NAME=portfolio-web