%!TEX TS-program = xelatex
\documentclass[10pt,a4paper]{article}

\usepackage[
  a4paper,
  top=8mm,
  bottom=13mm,
  left=0pt,
  right=0pt,
  includehead,
  includefoot,
  headheight=12pt,
  headsep=4mm,
  footskip=8mm
]{geometry}

\usepackage{fontspec}
\usepackage{xcolor}
\usepackage{enumitem}
\usepackage{hyperref}
\usepackage{microtype}
\usepackage{graphicx}
\usepackage{lastpage}
\usepackage{fancyhdr}
\usepackage{calc}
\usepackage{tikz}
\usepackage{setspace}
\usepackage{needspace}

%=============================================================================
% FONT FALLBACK
%=============================================================================
\IfFontExistsTF{Inter}{
  \setmainfont{Inter}
}{
  \IfFontExistsTF{Source Sans 3}{
    \setmainfont{Source Sans 3}
  }{
    \IfFontExistsTF{TeX Gyre Heros}{
      \setmainfont{TeX Gyre Heros}
    }{
      \setmainfont{Liberation Sans}
    }
  }
}

\setlength{\parindent}{0pt}
\setlength{\parskip}{0pt}
\setlength{\fboxsep}{0pt}
\raggedbottom
\emergencystretch=2em

% Avoid lonely first/last lines in normal paragraphs.
\clubpenalty=10000
\widowpenalty=10000
\displaywidowpenalty=10000

\hypersetup{hidelinks}
\def\UrlBreaks{\do\/\do-\do.\do=\do_\do?\do\&\do\#}

%=============================================================================
% COLORS
%=============================================================================
\definecolor{headerbg}{HTML}{f3f6f9}
\definecolor{sectionbg}{HTML}{dce5ee}
\definecolor{sectionfg}{HTML}{1a2e4a}
\definecolor{cvblue}{HTML}{1a2e4a}
\definecolor{accent}{HTML}{2a6ebb}
\definecolor{muted}{HTML}{3f3f3f}
\definecolor{medgray}{HTML}{666666}
\definecolor{dategray}{HTML}{888888}
\definecolor{lightgray}{HTML}{aaaaaa}
\definecolor{rulegray}{HTML}{d8dee6}

%=============================================================================
% LAYOUT LENGTHS
%=============================================================================
\newlength{\bodypad}
\setlength{\bodypad}{22mm}

\newlength{\leftcol}
\setlength{\leftcol}{36mm}

\newlength{\gutter}
\setlength{\gutter}{8mm}

\newlength{\rightcol}
\setlength{\rightcol}{\dimexpr\paperwidth-2\bodypad-\leftcol-\gutter\relax}

\newlength{\bodywidth}
\setlength{\bodywidth}{\dimexpr\paperwidth-2\bodypad\relax}

%=============================================================================
% PAGE STYLE
%=============================================================================
\pagestyle{fancy}
\fancyhf{}
\renewcommand{\headrulewidth}{0pt}
\renewcommand{\footrulewidth}{0pt}

\fancyhead[C]{%
  \makebox[\paperwidth][l]{%
    \hspace*{\bodypad}%
    \parbox[b]{\bodywidth}{%
      \raggedright
      {\fontsize{8pt}{10pt}\selectfont
      \color{medgray}\textbf{<< name|e >>}%
      \enspace\textcolor{lightgray}{|}\enspace
      << title|e >>}%
    }%
  }%
}

\fancyfoot[C]{%
  {\fontsize{7pt}{9pt}\selectfont
  \color{lightgray}\thepage\,/\,\pageref{LastPage}}%
}

\fancypagestyle{firstpage}{%
  \fancyhf{}%
  \renewcommand{\headrulewidth}{0pt}%
  \renewcommand{\footrulewidth}{0pt}%
  \fancyfoot[C]{%
    {\fontsize{7pt}{9pt}\selectfont
    \color{lightgray}\thepage\,/\,\pageref{LastPage}}%
  }%
}

%=============================================================================
% COMPONENTS
%=============================================================================
\newcommand{\skilltag}[1]{%
  \tikz[baseline=-1pt]\node[
    fill=headerbg,
    draw=rulegray,
    line width=0.25pt,
    text=cvblue,
    inner xsep=5pt,
    inner ysep=2.2pt,
    rounded corners=2pt,
    font=\fontsize{7.3pt}{8.8pt}\selectfont\bfseries
  ]{#1};\hspace{2pt}%
}

% Modern section header: compact uppercase label + thin rule.
\newcommand{\cvsection}[1]{%
  \par\Needspace{96pt}%
  \vspace{12pt}%
  \setlength{\leftskip}{0pt}%
  \setlength{\rightskip}{0pt}%
  \noindent\hspace*{\bodypad}%
  \begin{minipage}{\bodywidth}%
    {\fontsize{8.5pt}{10.5pt}\selectfont
    \bfseries\color{cvblue}\MakeUppercase{#1}}\par%
    \vspace{3pt}%
    {\color{rulegray}\rule{\linewidth}{0.7pt}}%
  \end{minipage}%
  \par\vspace{9pt}%
  \setlength{\leftskip}{\bodypad}%
  \setlength{\rightskip}{\bodypad}%
}

%=============================================================================
% BREAKABLE BUT PAGE-AWARE CV ENTRY
% #1 = role/title
% #2 = date + location
% #3 = company/institution
%=============================================================================
\newcommand{\cventrystart}[3]{%
  \par\Needspace{88pt}%
  \begingroup
  \begin{list}{}{%
    \setlength{\leftmargin}{\dimexpr\bodypad+\leftcol+\gutter\relax}%
    \setlength{\rightmargin}{\bodypad}%
    \setlength{\labelwidth}{0pt}%
    \setlength{\labelsep}{0pt}%
    \setlength{\itemindent}{0pt}%
    \setlength{\listparindent}{0pt}%
    \setlength{\parsep}{0pt}%
    \setlength{\topsep}{0pt}%
    \setlength{\partopsep}{0pt}%
    \setlength{\itemsep}{0pt}%
  }%
  \item[]%
  \makebox[0pt][r]{%
    \begin{minipage}[t]{\leftcol}%
      {\fontsize{7.5pt}{10pt}\selectfont\color{dategray}#2}%
    \end{minipage}%
    \hspace{\gutter}%
  }%
  {\fontsize{9.6pt}{12pt}\selectfont\bfseries\color{cvblue}#1}\par%
  \vspace{1pt}%
  {\fontsize{8.2pt}{10.5pt}\selectfont\color{medgray}\textit{#3}}\par%
  \vspace{3pt}%
  \fontsize{8.5pt}{11.5pt}\selectfont\color{muted}%
}

\newcommand{\cventryend}{%
  \end{list}%
  \par\vspace{8pt}%
  \endgroup
  \setlength{\leftskip}{\bodypad}%
  \setlength{\rightskip}{\bodypad}%
}

% Bullet list for experience entries.
% labelsep improves spacing between bullet and text.
\newenvironment{cvbullets}{%
  \Needspace{42pt}%
  \begin{itemize}[
    leftmargin=1em,
    labelsep=0.45em,
    itemsep=1.5pt,
    topsep=1pt,
    parsep=0pt,
    beginpenalty=10000,
    midpenalty=300,
    endpenalty=10000
  ]%
}{%
  \end{itemize}%
}

%=============================================================================
% PUBLICATION HELPERS
%=============================================================================
\newcommand{\pubgroup}[1]{%
  \par\Needspace{74pt}%
  \vspace{2pt}%
  \noindent\hspace*{\bodypad}%
  {\fontsize{7.8pt}{9.5pt}\selectfont
  \bfseries\color{accent}\MakeUppercase{#1}}%
  \par\vspace{5pt}%
}

\newcommand{\pubmetadoi}[1]{%
  \href{https://doi.org/#1}{\textcolor{accent}{doi:\nolinkurl{#1}}}%
}

\newcommand{\pubmetalink}[1]{%
  \href{#1}{\textcolor{accent}{[link]}}%
}

\newlist{publist}{enumerate}{1}
\setlist[publist]{%
  label=\arabic*.,
  leftmargin=\dimexpr\bodypad+1.5em\relax,
  rightmargin=\bodypad,
  labelsep=0.6em,
  itemsep=6pt,
  topsep=2pt,
  parsep=0pt,
  listparindent=0pt,
  itemindent=0pt,
  align=left,
  beginpenalty=10000,
  midpenalty=200,
  endpenalty=10000
}

\begin{document}
\thispagestyle{firstpage}

%=============================================================================
% HEADER
%=============================================================================
\noindent\colorbox{headerbg}{%
  \begin{minipage}[c][98pt][c]{\paperwidth}%
    \hspace{\bodypad}%
    <% if profile_image %>
    \begin{minipage}[c]{72pt}%
      \begin{tikzpicture}
        \clip (0,0) circle (34pt);
        \node at (0,0) {%
          \includegraphics[width=68pt,height=68pt,keepaspectratio]{\detokenize{<< profile_image >>}}%
        };
      \end{tikzpicture}%
    \end{minipage}%
    \hspace{14pt}%
    <% endif %>
    \begin{minipage}[c]{\dimexpr\paperwidth-\bodypad-<% if profile_image %>86pt<% else %>\bodypad<% endif %>\relax}%
      {\fontsize{22pt}{26pt}\selectfont\bfseries\color{cvblue}<< name|e >>}\par%
      \vspace{3pt}%
      {\fontsize{10pt}{13pt}\selectfont\color{medgray}<< title|e >>}\par%
      \vspace{8pt}%
      {\fontsize{8pt}{11pt}\selectfont\color{medgray}%
        << email|e >>%
        <% if github %>\enspace\textcolor{lightgray}{·}\enspace << github|e >><% endif %>%
        <% if linkedin %>\enspace\textcolor{lightgray}{·}\enspace << linkedin|e >><% endif %>%
      }%
    \end{minipage}%
  \end{minipage}%
}

\par\vspace{8pt}

\setlength{\leftskip}{\bodypad}
\setlength{\rightskip}{\bodypad}

%=============================================================================
% PROFILE / SUMMARY
% Optional. Requires a variable named profile_summary.
%=============================================================================
<% if profile_summary is defined and profile_summary %>
\cvsection{Profile}
{\fontsize{8.7pt}{12pt}\selectfont\color{muted}%
<< profile_summary|e >>\par}
\vspace{2pt}
<% endif %>

%=============================================================================
% SKILLS
%=============================================================================
<% if skill_groups is defined and skill_groups %>
\cvsection{Skills}

<% for group in skill_groups %>
\noindent
{\fontsize{8.4pt}{11pt}\selectfont\bfseries\color{cvblue}<< group.label|e >>:}%
\enspace
{\fontsize{8.4pt}{11pt}\selectfont\color{muted}%
<% for skill in group.skills %>
<< skill.name|e >><% if not loop.last %>, <% endif %>
<% endfor %>
}%
\par\vspace{4pt}
<% endfor %>

\vspace{2pt}

<% elif skills %>
\cvsection{Skills}

{\setstretch{1.85}%
<% for skill in skills %>
\skilltag{<< skill.name|e >>}%
<% endfor %>
\par}

\vspace{4pt}
<% endif %>

%=============================================================================
% LANGUAGES
%=============================================================================
<% if languages %>
\cvsection{Languages}

<% for lang in languages %>
\noindent
\begin{minipage}[t]{5cm}%
  {\fontsize{8.7pt}{11.5pt}\selectfont\bfseries\color{cvblue}<< lang.name|e >>}%
\end{minipage}%
\begin{minipage}[t]{6cm}%
  {\fontsize{8.3pt}{11.5pt}\selectfont\color{medgray}<< lang.get_level_display()|e >>}%
\end{minipage}%
\par\vspace{4pt}%
<% endfor %>

\vspace{3pt}
<% endif %>

%=============================================================================
% EXPERIENCE
%=============================================================================
<% if experiences %>
\cvsection{Professional Experience}

<% for exp in experiences %>
\cventrystart%
  {<< exp.role|e >>}%
  {<< exp.start_year >>--<< exp.end_year if exp.end_year else 'Present' >><% if exp.location %>\\\textit{<< exp.location|e >>}<% endif %>}%
  {<< exp.company|e >>}%

<% if exp.blurb %>
<< exp.blurb|e >>\par\vspace{3pt}
<% endif %>

<% set bullets = exp.bullets.all() %>
<% if bullets %>
\begin{cvbullets}
<% for b in bullets %>
\item << b.text|e >>
<% endfor %>
\end{cvbullets}
<% endif %>

\cventryend
<% endfor %>
<% endif %>

%=============================================================================
% EDUCATION
%=============================================================================
<% if educations %>
\cvsection{Education}

<% for edu in educations %>
\cventrystart%
  {<< edu.title|e >>}%
  {<< edu.start_year >>--<< edu.end_year if edu.end_year else 'Present' >><% if edu.location %>\\\textit{<< edu.location|e >>}<% endif %>}%
  {<< edu.institution|e >>}%

<% if edu.blurb %>
<< edu.blurb|e >>
<% endif %>

\cventryend
<% endfor %>
<% endif %>

%=============================================================================
% GRANTS & FUNDING
%=============================================================================
<% if grants %>
\cvsection{Grants \& Funding}

<% for g in grants %>
\cventrystart%
  {<< g.title|e >>}%
  {<% if g.start_year %><< g.start_year >><% if g.end_year %>--<< g.end_year >><% endif %><% endif %>}%
  {<< g.funder|e >><% if g.role %> · << g.role|e >><% endif %><% if g.amount %> · << g.amount|e >><% endif %>}%

<% if g.description %>
<< g.description|e >>
<% endif %>

\cventryend
<% endfor %>
<% endif %>

%=============================================================================
% AWARDS & HONOURS
%=============================================================================
<% if awards %>
\cvsection{Awards \& Honours}

<% for a in awards %>
\cventrystart%
  {<< a.title|e >>}%
  {<< a.year if a.year else '' >>}%
  {<< a.issuer|e >>}%

<% if a.description %>
<< a.description|e >>
<% endif %>

\cventryend
<% endfor %>
<% endif %>

%=============================================================================
% PUBLICATIONS
%=============================================================================
<% if pub_groups %>
\Needspace{120pt}
\cvsection{Publications}

<% for group in pub_groups %>
\pubgroup{<< group.label|e >>}

\begin{publist}
<% for pub in group.pubs %>
\item {\fontsize{8.5pt}{12pt}\selectfont\color{muted}\raggedright
  << pub.authors_display|authors_latex >> (<< pub.year >>).
  \textbf{\textcolor{cvblue}{<< pub.title|e >>}}.
  \textit{<< pub.venue|e >>}.%
  \par
  <% if pub.doi or pub.link or pub.citation_count %>
  \vspace{1pt}%
  {\fontsize{7.4pt}{9pt}\selectfont\color{medgray}%
    <% if pub.doi %>
    \pubmetadoi{<< pub.doi|e >>}%
    <% elif pub.link %>
    \pubmetalink{<< pub.link|e >>}%
    <% endif %>
    <% if pub.citation_count %>
      <% if pub.doi or pub.link %>
      \enspace\textcolor{lightgray}{·}\enspace
      << pub.citation_count >> citations%
      <% else %>
      Citations: << pub.citation_count >>%
      <% endif %>
    <% endif %>
  }%
  \par
  <% endif %>
}
<% endfor %>
\end{publist}

\vspace{6pt}%
<% endfor %>
<% endif %>

\end{document}