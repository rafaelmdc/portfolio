# Internal/in-cluster URL of the headless Wagtail backend.
#
# Used ONLY for server-side (SSR) JSON fetches. The browser never uses this —
# images, documents, the CV and any API calls are served same-origin and
# proxied to the backend by next.config `rewrites()`. So the backend can stay
# in-network only (not publicly reachable); reach the CMS over LAN/VPN.

# Local dev (docker compose stack on :8000):
INTERNAL_API_URL=http://localhost:8000

# Production example (in-cluster Service, NOT public):
# INTERNAL_API_URL=http://portfolio-web:8000

# (WAGTAIL_API_URL is still honoured as a fallback for INTERNAL_API_URL.)
