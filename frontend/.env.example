# Base URL of the headless Wagtail backend.
#
# Used for BOTH server-side JSON fetches AND the image/media URLs that end up in
# the HTML (loaded by the browser). It must therefore be PUBLICLY REACHABLE in
# production — use the backend's public URL, not an internal-only Service name.

# Local dev (docker compose stack on :8000):
WAGTAIL_API_URL=http://localhost:8000

# Production example (public backend domain):
# WAGTAIL_API_URL=https://api.rafael.duarte-correia.pt
